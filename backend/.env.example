# Database
DATABASE_URL=sqlite:///./crm.db

# Security (REQUIRED - generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-generate-a-real-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Token encryption for OAuth tokens at rest (REQUIRED for Gmail integration)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# CORS
FRONTEND_URL=http://localhost:8080
EXTRA_CORS_ORIGINS=

# Email (SMTP) - Optional, for password reset functionality
# Leave empty to use development mode (prints to console)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@pretorin.com
SMTP_FROM_NAME=Pretorin CRM

# Google Integration - Optional
# Create OAuth2 credentials at https://console.cloud.google.com/apis/credentials
# Used for both Google Sign-In (IDP) and Gmail integration
# For Google Sign-In: add your frontend URL as an authorized JavaScript origin
# For Gmail: enable the Gmail API at https://console.cloud.google.com/apis/library/gmail.googleapis.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/gmail/callback
GOOGLE_PUBSUB_TOPIC=

# Gmail Webhook Authentication - Optional
# Set a shared secret to verify incoming Pub/Sub webhook requests
GMAIL_WEBHOOK_TOKEN=

# Sentry Error Reporting - Optional
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
