# Local development configuration
# Usage: docker compose --env-file dev.env up --build
# Or source individual values for running services outside Docker.

# Backend
SECRET_KEY=dev-secret-key-change-in-production
DATABASE_URL=postgresql://crm:crm@localhost/crm
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
FRONTEND_URL=http://localhost:5173
TOKEN_ENCRYPTION_KEY=
ENV=development
LOG_LEVEL=DEBUG

# Postgres
POSTGRES_USER=crm
POSTGRES_PASSWORD=crm
POSTGRES_DB=crm

# Google Integration (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_PUBSUB_TOPIC=

# Email (SMTP - optional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=

# Frontend
VITE_API_BASE_URL=http://localhost:8000
