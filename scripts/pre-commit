#!/usr/bin/env bash
set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

cd "$(git rev-parse --show-toplevel)/backend"

if [ -f .venv/bin/activate ]; then
    source .venv/bin/activate
fi

echo "=== Running ruff linter ==="
if ! ruff check .; then
    echo -e "${RED}Lint check failed. Fix errors before committing.${NC}"
    exit 1
fi
echo -e "${GREEN}Lint check passed.${NC}"

echo ""
echo "=== Running tests with coverage ==="
if ! pytest --cov=app --cov-report=term-missing --cov-fail-under=100 -q -W error::UserWarning -W error::FutureWarning; then
    echo -e "${RED}Tests failed or coverage is below 100%. Fix before committing.${NC}"
    exit 1
fi
echo -e "${GREEN}All tests passed with 100% coverage.${NC}"

echo ""
echo "=== Checking for test warnings ==="
WARNING_OUTPUT=$(pytest -q --tb=no 2>&1 | grep -E "^[0-9]+ passed" || true)
if echo "$WARNING_OUTPUT" | grep -q "warning"; then
    echo -e "${RED}Tests produced warnings:${NC}"
    pytest -q --tb=no 2>&1 | tail -20
    exit 1
fi
echo -e "${GREEN}No test warnings.${NC}"

echo ""
echo "=== Running pip-audit ==="
if ! pip-audit --desc --skip-editable; then
    echo -e "${RED}pip-audit found vulnerabilities. Fix before committing.${NC}"
    exit 1
fi
echo -e "${GREEN}pip-audit passed.${NC}"
